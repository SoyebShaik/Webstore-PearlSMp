body {
    background-color: #0f172a; /* The exact ShulkerMC Navy */
    color: #f1f5f9;
    font-family: 'Inter', sans-serif;
    margin: 0;
}

/* Fixed the extension issue here */
.shulker-wrapper {
    max-width: 1100px; /* Extends wide on Desktop */
    margin: 0 auto;
    padding: 20px;
}

.shulker-logo {
    text-align: center;
    padding: 50px 0;
}

.shulker-logo img {
    max-width: 220px;
}

.welcome-section {
    background: #1e293b; /* Lighter panel color */
    border-radius: 8px;
    padding: 40px;
    margin-top: 20px;
    border-bottom: 4px solid #3b82f6;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

.section-header {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 25px;
    display: flex;
    align-items: center;
    gap: 12px;
}

.section-header span { color: #3b82f6; }

.welcome-body {
    color: #94a3b8;
    line-height: 1.8;
    font-size: 16px;
}

.welcome-body a { color: #3b82f6; text-decoration: none; font-weight: 600; }
.welcome-body strong { color: #fff; display: block; margin-top: 20px; font-size: 18px; }
