:root {
    --shulker-bg: #0f172a; /* Lighter, professional blue-black */
    --shulker-panel: #1e293b; /* Panel color */
    --shulker-blue: #3b82f6;
    --shulker-border: rgba(255,255,255,0.1);
}

.nav-container {
    background: var(--shulker-panel);
    border-radius: 8px;
    margin-top: 20px;
    border: 1px solid var(--shulker-border);
    width: 100%; /* Allows it to extend */
}

/* On Desktop, show links horizontally */
@media screen and (min-width: 1000px) {
    .category-header { display: none; } /* Hide 'Choose Category' on desktop */
    .nav-links { 
        display: flex !important; 
        flex-direction: row; 
        justify-content: center;
    }
    .nav-links a { border-bottom: none; border-right: 1px solid var(--shulker-border); }
}

.nav-links a {
    padding: 15px 25px;
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
}

.user-control-bar {
    background: #111b2d;
    display: flex;
    justify-content: space-between;
    padding: 12px 25px;
    align-items: center;
}

.user-login { display: flex; align-items: center; gap: 10px; cursor: pointer; }
.user-login img { width: 32px; height: 32px; border-radius: 4px; }

.currency-wrap { position: relative; display: flex; align-items: center; gap: 15px; }
.currency-trigger { 
    display: flex; align-items: center; gap: 8px; font-size: 14px; 
    background: #1e293b; padding: 6px 15px; border-radius: 4px; cursor: pointer;
}

.currency-dropdown {
    display: none;
    position: absolute;
    top: 120%; right: 0;
    background: var(--shulker-panel);
    border: 1px solid var(--shulker-blue);
    grid-template-columns: repeat(2, 1fr);
    padding: 10px; z-index: 1000;
}
.currency-dropdown.show { display: grid; }
.currency-dropdown div { padding: 8px; cursor: pointer; font-size: 13px; font-weight: bold; }

.basket-icon { color: var(--shulker-blue); font-size: 20px; }

/* Modal Styles */
.modal-overlay {
    display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8);
    z-index: 9999; align-items: center; justify-content: center;
}
.modal-overlay.active { display: flex; }
.modal-content {
    background: var(--shulker-panel); padding: 40px; border-radius: 8px;
    text-align: center; width: 95%; max-width: 450px; border: 1px solid var(--shulker-border);
}
